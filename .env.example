# =============================================================================
# QUÉ ES ESTE ARCHIVO
# =============================================================================
# `.env.example` NO lo usa Next.js ni el helper: es solo plantilla / documentación
# versionada en el repo para saber qué variables existen.
#
# Los valores reales van en `.env.local` (en tu máquina; no se sube a git).
# Next.js carga `.env.local` al arrancar y expone las vars en `process.env`;
# `src/lib/env/supabase.ts` lee `NEXT_PUBLIC_*` y `SUPABASE_*` desde ahí.
#
# Copiá bloques de abajo a tu `.env.local` y completá los valores.
# =============================================================================

# URL canónica del sitio (sin barra final), opcional. Ej.: https://www.karubox.com.py
# NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# Supabase — target y credenciales
# -----------------------------------------------------------------------------
# prod | preprod (si no definís nada, el código asume prod).
NEXT_PUBLIC_SUPABASE_TARGET=prod

# --- Producción (proyecto Supabase "prod") ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Preproducción (otro proyecto Supabase; solo se usan si TARGET=preprod) ---
NEXT_PUBLIC_SUPABASE_URL_PREPROD=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PREPROD=
SUPABASE_SERVICE_ROLE_KEY_PREPROD=

# Al cambiar de target: son BDs distintas → cerrá sesión o borrá cookies.
# Tras editar NEXT_PUBLIC_* reiniciá `next dev`.

# -----------------------------------------------------------------------------
# POS — redondeo del precio de extras (opcional)
# -----------------------------------------------------------------------------
# Paso en guaraníes. Ej.: 1000 para mostrar/cobrar extras en miles (732 → 1000).
# 0 o vacío = sin redondeo en el POS (se usa el precio_publico tal cual en BD).
# NEXT_PUBLIC_EXTRAS_PRECIO_REDONDE_PASO=1000
# nearest = al múltiplo más cercano (mín. 1 paso si el monto es > 0).
# ceil = siempre hacia arriba (ej. 732 → 1000, 2000 → 2000).
# NEXT_PUBLIC_EXTRAS_PRECIO_REDONDE_MODO=nearest

# -----------------------------------------------------------------------------
# Resend (opcional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# RESEND_FROM=Atlas Burger <campanas@tudominio.com>
RESEND_FROM=
