# Supabase (obligatorio en local: .env.local)
# En Vercel: Production = proyecto Supabase de producción; Preview = proyecto Supabase staging/preprod.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (necesario para subir foto del local en Configuración). Creá un bucket "logos" en Storage (público).
# En Preview, usá la service_role del proyecto staging (nunca la de prod en previews públicos).
SUPABASE_SERVICE_ROLE_KEY=

# Solo para aplicar el esquema en staging desde tu máquina (npm run db:apply-staging). No commitees valores reales.
# URI: Supabase Dashboard → proyecto staging → Settings → Database → Connection string (URI).
# DATABASE_URL=

# Resend - envío de emails de campaña (opcional, plan gratuito 3000/mes)
# API Key: https://resend.com
RESEND_API_KEY=
# Para enviar a TODOS los clientes (no solo al email de tu cuenta): verificá un dominio en
# Resend (resend.com/domains) y definí el remitente. Ejemplo:
# RESEND_FROM=Atlas Burger <campanas@tudominio.com>
RESEND_FROM=
