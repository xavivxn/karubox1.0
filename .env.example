# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (necesario para subir foto del local en Configuración). Creá un bucket "logos" en Storage (público).
SUPABASE_SERVICE_ROLE_KEY=

# Resend - envío de emails de campaña (opcional, plan gratuito 3000/mes)
# API Key: https://resend.com
RESEND_API_KEY=
# Para enviar a TODOS los clientes (no solo al email de tu cuenta): verificá un dominio en
# Resend (resend.com/domains) y definí el remitente. Ejemplo:
# RESEND_FROM=Atlas Burger <campanas@tudominio.com>
RESEND_FROM=
